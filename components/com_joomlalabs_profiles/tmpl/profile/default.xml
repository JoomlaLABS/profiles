<?xml version="1.0" encoding="UTF-8"?>
<metadata>
	<layout title="COM_JOOMLALABS_PROFILES_PROFILE_VIEW_DEFAULT_TITLE" option="COM_JOOMLALABS_PROFILES_PROFILE_VIEW_DEFAULT_OPTION">
		<message><![CDATA[COM_JOOMLALABS_PROFILES_PROFILE_VIEW_DEFAULT_DESC]]></message>
	</layout>

	<fields name="request">
		<fieldset name="request" addfieldprefix="JoomlaLabs\Component\Profiles\Administrator\Field">
			<field
				name="id"
				type="ModalSelect"
				label="COM_JOOMLALABS_PROFILES_FIELD_SINGLE_PROFILE_LABEL"
				description="COM_JOOMLALABS_PROFILES_FIELD_SINGLE_PROFILE_DESC"
				required="true"
				select="true"
				clear="true"
				urlSelect="index.php?option=com_joomlalabs_profiles&amp;view=profiles&amp;layout=modal&amp;tmpl=component"
				titleSelect="COM_JOOMLALABS_PROFILES_SELECT_A_PROFILE"
				sql_title_table="#__joomlalabs_profiles"
				sql_title_column="display_name"
				sql_title_key="id"
			>
			</field>
		</fieldset>
	</fields>

	<fields name="params">
		<fieldset name="basic" label="COM_MENUS_BASIC_FIELDSET_LABEL">
			<field
				name="profile_layout"
				type="ProfileLayout"
				label="COM_JOOMLALABS_PROFILES_FIELD_PROFILE_LAYOUT_LABEL"
				description="COM_JOOMLALABS_PROFILES_FIELD_PROFILE_LAYOUT_SINGLE_DESC"
				class="form-select"
				default="default"
			/>

			<field
				name="show_profile_category"
				type="radio"
				layout="joomla.form.field.radio.switcher"
				label="COM_JOOMLALABS_PROFILES_FIELD_SHOW_PROFILE_CATEGORY_LABEL"
				default="1"
			>
				<option value="0">JNO</option>
				<option value="1">JYES</option>
			</field>
		</fieldset>
	</fields>
</metadata>