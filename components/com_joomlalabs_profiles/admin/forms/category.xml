<?xml version="1.0" encoding="UTF-8"?>
<form>
	<help key="Categories:_Edit_Category" />
	<listhelp key="Categories:_Categories" />

	<fields name="params">
		<fieldset name="profiles" label="COM_JOOMLALABS_PROFILES_CATEGORY_POLICY_FIELDSET_LABEL">
			<field
				name="display_name_pattern"
				type="text"
				label="COM_JOOMLALABS_PROFILES_CATEGORY_DISPLAY_NAME_PATTERN_LABEL"
				description="COM_JOOMLALABS_PROFILES_CATEGORY_DISPLAY_NAME_PATTERN_DESC"
			/>

			<field
				name="user_link_policy"
				type="list"
				label="COM_JOOMLALABS_PROFILES_CATEGORY_USER_LINK_POLICY_LABEL"
				default="optional-many"
				validate="options"
			>
				<option value="optional-many">COM_JOOMLALABS_PROFILES_CATEGORY_USER_LINK_POLICY_OPTIONAL_MANY</option>
				<option value="required-many">COM_JOOMLALABS_PROFILES_CATEGORY_USER_LINK_POLICY_REQUIRED_MANY</option>
				<option value="optional-single">COM_JOOMLALABS_PROFILES_CATEGORY_USER_LINK_POLICY_OPTIONAL_SINGLE</option>
				<option value="required-single">COM_JOOMLALABS_PROFILES_CATEGORY_USER_LINK_POLICY_REQUIRED_SINGLE</option>
			</field>

			<field
				name="is_public_directory"
				type="radio"
				layout="joomla.form.field.radio.switcher"
				label="COM_JOOMLALABS_PROFILES_CATEGORY_IS_PUBLIC_DIRECTORY_LABEL"
				default="0"
			>
				<option value="0">JNO</option>
				<option value="1">JYES</option>
			</field>
		</fieldset>
	</fields>
</form>
